#!/usr/bin/env bash
# Reads mPrimary from Noctalia colors.json and dynamically derives
# shadow/accent-dark/accent by darkening it, then applies to Papirus-Dark.

set -euo pipefail

COLORS_JSON="${HOME}/.config/noctalia/colors.json"
THEME="Papirus-Dark"
PAPIRUS_FOLDERS="/home/himanshu/Documents/zynori-bootc/files/niri-settings/usr/bin/papirus-folders"

# --- Read mPrimary hex ---
accent_hex=$(python3 -c "
import json
with open('${COLORS_JSON}') as f:
    d = json.load(f)
print(d['mPrimary'].lstrip('#'))
")

# --- Derive shadow and accent-dark by darkening mPrimary ---
best=$(ACCENT_HEX="$accent_hex" python3 <<'EOF'
import sys
import os

def darken(hex_str, factor):
    r, g, b = (int(hex_str[i:i+2], 16) for i in (0, 2, 4))
    r = max(0, int(r * (1 - factor)))
    g = max(0, int(g * (1 - factor)))
    b = max(0, int(b * (1 - factor)))
    return f"#{r:02x}{g:02x}{b:02x}"

_accent_hex = os.environ["ACCENT_HEX"]

accent      = f"#{_accent_hex}"
accent_dark = darken(_accent_hex, 0.20)
shadow      = darken(_accent_hex, 0.60)

print(f"[dynamic] mPrimary={accent} → shadow={shadow} accent-dark={accent_dark} accent={accent}", file=sys.stderr)
print(f"noctalia-dynamic\n{shadow}\n{accent_dark}\n{accent}")
EOF
)

{ read -r color_name; read -r shadow; read -r accent_dark; read -r accent; } <<< "$best"
sudo "$PAPIRUS_FOLDERS" -t "$THEME" -N "$color_name" \
    --shadow "$shadow" \
    --accent-dark "$accent_dark" \
    --accent "$accent"