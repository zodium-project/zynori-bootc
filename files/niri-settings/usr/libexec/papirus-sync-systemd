#!/usr/bin/env bash
set -euo pipefail

find_human_user() {
    local user uid
    while read -r user; do
        uid=$(getent passwd "$user" 2>/dev/null | cut -d: -f3) || continue
        [ -n "$uid" ] || continue
        [ "$uid" -ge 1000 ] && [ "$uid" -lt 65534 ] && echo "$user" && return 0
    done < <(loginctl list-sessions --no-legend | awk '{print $3}' | sort -u)
    getent passwd | awk -F: '$3 >= 1000 && $3 < 65534 {print $1; exit}'
}

apply_accent() {
    local colors_json="$1"

    accent_hex=$(python3 -c "
import json
with open('$colors_json') as f:
    d = json.load(f)
print(d['mPrimary'].lstrip('#'))
")

    # Pure bash hex darkening — no python needed
    darken() {
        local hex="$1" factor="$2"
        local r g b
        r=$(( 16#${hex:0:2} ))
        g=$(( 16#${hex:2:2} ))
        b=$(( 16#${hex:4:2} ))
        r=$(( r * (100 - factor) / 100 ))
        g=$(( g * (100 - factor) / 100 ))
        b=$(( b * (100 - factor) / 100 ))
        printf "#%02x%02x%02x" $r $g $b
    }

    local accent="#${accent_hex}"
    local accent_dark shadow
    accent_dark=$(darken "$accent_hex" 20)
    shadow=$(darken "$accent_hex" 60)

    echo "papirus-sync-systemd: applying accent=$accent shadow=$shadow accent_dark=$accent_dark"

    /usr/bin/papirus-folders -t "Papirus-Dark" -N "noctalia-dynamic" \
        --shadow      "$shadow" \
        --accent-dark "$accent_dark" \
        --accent      "$accent"
}

# Wait for a human user to be available
until REAL_USER=$(find_human_user) && [ -n "$REAL_USER" ]; do
    sleep 2
done

REAL_HOME=$(getent passwd "$REAL_USER" | cut -d: -f6)
WATCH_DIR="$REAL_HOME/.cache/noctalia"
COLORS_JSON="$REAL_HOME/.config/noctalia/colors.json"

echo "papirus-sync-systemd: watching '$WATCH_DIR' for '$REAL_USER'"

# Apply once on startup
[ -f "$COLORS_JSON" ] && apply_accent "$COLORS_JSON"

# Watch for changes with proper debounce via inotifywait
inotifywait -m -e close_write --format '%f' "$WATCH_DIR" 2>/dev/null | \
while read -r changed; do
    case "$changed" in
        theming.dynamic.toml|theming.predefined.toml|predefined-scheme.json)
            echo "papirus-sync-systemd: '$changed' changed, syncing..."
            sleep 2  # debounce — noctalia may write multiple files rapidly
            apply_accent "$COLORS_JSON"
            ;;
    esac
done