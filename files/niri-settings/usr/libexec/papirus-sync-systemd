#!/usr/bin/env bash
set -euo pipefail

LOCK="/run/papirus-accent.lock"
PENDING="/run/papirus-accent.pending"

# --- Logging ---
log() { echo "papirus-sync-systemd: $*" | systemd-cat -t papirus-accent -p info; }
err() { echo "papirus-sync-systemd: $*" | systemd-cat -t papirus-accent -p err; }

# --- Cleanup on exit ---
trap 'rm -f "$LOCK" "$PENDING"; wait' EXIT INT TERM

find_human_user() {
    local user uid
    while read -r user; do
        uid=$(getent passwd "$user" 2>/dev/null | cut -d: -f3) || continue
        [ -n "$uid" ] || continue
        [ "$uid" -ge 1000 ] && [ "$uid" -lt 65534 ] && echo "$user" && return 0
    done < <(loginctl list-sessions --no-legend | awk '{print $3}' | sort -u)
    getent passwd | awk -F: '$3 >= 1000 && $3 < 65534 {print $1; exit}'
}

darken() {
    local hex="$1" factor="$2"
    local r g b
    r=$(( 16#${hex:0:2} ))
    g=$(( 16#${hex:2:2} ))
    b=$(( 16#${hex:4:2} ))
    r=$(( r * (100 - factor) / 100 ))
    g=$(( g * (100 - factor) / 100 ))
    b=$(( b * (100 - factor) / 100 ))
    printf "#%02x%02x%02x" $r $g $b
}

apply_accent() {
    local colors_json="$1"

    # Guard — colors.json may not exist yet
    if [ ! -f "$colors_json" ]; then
        err "colors.json missing at '$colors_json', skipping"
        return 0
    fi

    local accent_hex
    accent_hex=$(python3 -c "
import json
with open('$colors_json') as f:
    d = json.load(f)
print(d['mPrimary'].lstrip('#'))
") || { err "failed to parse colors.json"; return 0; }

    local accent accent_dark shadow
    accent="#${accent_hex}"
    accent_dark=$(darken "$accent_hex" 20)
    shadow=$(darken "$accent_hex" 60)

    log "applying accent=$accent shadow=$shadow accent_dark=$accent_dark"

    # Sync shared base assets (Papirus) — no recoloring needed
    rsync -a --mkpath --delete /usr/share/icons/Papirus/ \
        "$REAL_HOME/.local/share/icons/Papirus/" \
        || err "rsync Papirus (base) failed"
    chown -R "$REAL_USER:$REAL_USER" "$REAL_HOME/.local/share/icons/Papirus/" \
        || err "chown Papirus (base) failed"

    # Sync clean upstream icons into user home before recoloring
    rsync -a --mkpath --delete /usr/share/icons/Papirus-Dark/ \
        "$REAL_HOME/.local/share/icons/Papirus-Dark/" \
        || err "rsync Papirus-Dark failed"
    chown -R "$REAL_USER:$REAL_USER" "$REAL_HOME/.local/share/icons/Papirus-Dark/" \
        || err "chown Papirus-Dark failed"

    if ! THEME_DIR="$REAL_HOME/.local/share/icons/Papirus-Dark" \
        SYNC_FILE="$REAL_HOME/.cache/papirus-accent/sync" \
        /usr/libexec/papirus-color-sync \
        --shadow      "$shadow" \
        --accent-dark "$accent_dark" \
        --accent      "$accent"; then
        err "papirus-color-sync failed, will retry on next theme change"
        return 0
    fi
}

apply_worker() {
    (
        flock -n 9 || exit 0  # another worker holds lock, it will handle pending

        while [ -f "$PENDING" ]; do
            rm -f "$PENDING"
            sleep 1  # colors.json is the final write, minimal settle needed
        done

        apply_accent "$COLORS_JSON"

    ) 9>"$LOCK"

    # Reap any finished background workers
    wait -n 2>/dev/null || true
}

# --- Wait for human user ---
until REAL_USER=$(find_human_user) && [ -n "$REAL_USER" ]; do
    log "waiting for human user..."
    sleep 2
done

REAL_HOME=$(getent passwd "$REAL_USER" | cut -d: -f6)

WATCH_DIR="$REAL_HOME/.config/noctalia"
COLORS_JSON="$REAL_HOME/.config/noctalia/colors.json"

# --- Wait for watch dir to exist ---
until [ -d "$WATCH_DIR" ]; do
    log "waiting for '$WATCH_DIR' to exist..."
    sleep 2
done

log "watching '$WATCH_DIR' for '$REAL_USER'"

# --- Apply once on startup ---
apply_accent "$COLORS_JSON"

# --- Watch for changes, restart inotifywait if it dies ---
while true; do
    inotifywait -m -e close_write -e moved_to --format '%f' "$WATCH_DIR" 2>/dev/null | \
    while read -r changed; do
        case "$changed" in
            colors.json)
                log "'$changed' changed, queuing..."
                touch "$PENDING"
                apply_worker &
                ;;
        esac
    done

    err "inotifywait exited unexpectedly, restarting watch in 1s..."
    sleep 1
done
